/-
If a graph is well-formed, its node labels are unique.
-/
theorem DagLeanLibrary.SpecialDAG.Graph.nodeLabels_injective_of_wellFormed (g : Graph) (hWF : WellFormed Graph g) :
    (g.nodeLabels.toList.map Prod.snd).Nodup := by
  convert hWF.nodeLabelRoundTrip using 1;
  constructor;
  · exact?;
  · intro h
    have h_unique_vals : ∀ l n₁ n₂, (n₁, l) ∈ g.nodeLabels.toList → (n₂, l) ∈ g.nodeLabels.toList → n₁ = n₂ := by
      intros l n₁ n₂ hn₁ hn₂;
      have := h n₁ l ?_ <;> have := h n₂ l ?_ <;> aesop;
    rw [ List.nodup_map_iff_inj_on ];
    · aesop;
    · have h_nodup_keys : ∀ m : Std.HashMap NodeId String, (m.toList.map Prod.fst).Nodup := by
        exact?;
      exact?


-/
theorem DagLeanLibrary.SpecialDAG.Graph.simpleAdjacency_of_graph (g : Graph) :
    ∀ n, (g.predecessors n).Nodup ∧ (g.successors n).Nodup := by
  intro n
  simp [predecessors, successors];
  have h_eraseDups_Nodup : ∀ l : List NodeId, List.Nodup (List.eraseDupsBy (fun x y => x == y) l) := by
    intro l; induction l <;> simp_all +decide [ List.eraseDupsBy ] ;
    -- By definition of `List.eraseDupsBy.loop`, the accumulator `acc` is nodup after each step.
    have h_loop_nodup : ∀ (acc : List NodeId) (l : List NodeId), List.Nodup acc → List.Nodup (List.eraseDupsBy.loop (fun x y => x == y) l acc) := by
      intros acc l hacc; induction l generalizing acc <;> simp_all +decide [ List.eraseDupsBy.loop ] ;
      by_cases h : ‹NodeId› ∈ acc <;> simp_all +decide [ List.any_eq ];
    exact h_loop_nodup _ _ ( by simp +decide );
  exact ⟨ h_eraseDups_Nodup _, h_eraseDups_Nodup _ ⟩

/-
If a node is incident to any edge (either as source or destination), then it has either a predecessor or a successor.
-/
theorem DagLeanLibrary.SpecialDAG.Graph.incident_implies_pred_or_succ {g : Graph} {n : NodeId} :
  (g.edges.any (fun (u, v) => u == n || v == n)) = true →
  g.predecessors n ≠ [] ∨ g.successors n ≠ [] := by
  intro h;
  contrapose! h; simp_all +decide [ Graph.predecessors, Graph.successors ] ;
  have h_eraseDups : ∀ {l : List NodeId}, (l.eraseDups = []) → l = [] := by
    intros l hl; induction l <;> simp_all +decide [ List.eraseDups_cons ] ;
  grind


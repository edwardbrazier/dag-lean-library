  simp_all +decide [ Std.HashMap.ofList, List.lookup ];
  unfold Std.DHashMap.Const.ofList; simp_all +decide [ Std.DHashMap.Const.ofList ] ;
  simp_all +decide [ Std.DHashMap.Const.insertMany ];
  simp_all +decide [ Std.DHashMap.Internal.Raw₀.Const.insertMany ];
  rename_i l a;
  by_cases hk : k == l.1 <;> simp_all +decide [ Std.HashMap.getElem?_insert ];
  · convert Std.HashMap.getElem?_insert_self using 1;
    rotate_left;
    exact α;
    exact?;
    exact?;
    exact?;
    exact?;
    exact?;
    exact l.1;
    congr;
    · unfold Std.DHashMap.Internal.Raw₀.Const.insertMany; aesop;
    · rw [ List.lookup_eq_none_iff.mpr ] <;> aesop;
  · convert a using 1;
    · -- Since inserting a new key into a HashMap doesn't change the existing entries, the get? operation on the modified HashMap is the same as on the original HashMap.
      have h_insert : ∀ (m : Std.HashMap α β) (k : α) (v : β), k ≠ l.1 → (m.insert l.1 v)[k]? = m[k]? := by

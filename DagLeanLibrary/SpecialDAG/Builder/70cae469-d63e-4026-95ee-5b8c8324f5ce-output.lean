  -- By definition of `Std.HashMap.ofList`, we can rewrite the right-hand side of the equation.
  have h_ofList : ∀ (l : List (String × NodeId)), Std.HashMap.ofList l = List.foldl (fun acc (k, v) => acc.insert k v) ∅ l := by
    intro l; exact (by
    induction l using List.reverseRecOn <;> simp +decide [ * ];
    simp +decide [ ← ‹_›, Std.HashMap.ofList ];
    simp +decide [ Std.DHashMap.Const.ofList ];
    simp +decide [ Std.DHashMap.Const.insertMany ];
    simp +decide [ Std.DHashMap.Internal.Raw₀.Const.insertMany ];
    congr);
  convert h_ofList _ using 1;

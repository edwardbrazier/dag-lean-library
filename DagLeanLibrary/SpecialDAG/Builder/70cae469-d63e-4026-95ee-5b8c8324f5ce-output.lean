/-
Looking up a key in a HashMap is equivalent to looking it up in its list representation.
-/
theorem DagLeanLibrary.SpecialDAG.Graph.HashMap_get?_eq_lookup {α β : Type} [BEq α] [Hashable α] [EquivBEq α] [LawfulHashable α] [LawfulBEq α]
    (m : Std.HashMap α β) (k : α) :
    m.get? k = m.toList.lookup k := by
  rw [ eq_comm ];
  -- Since the keys in `m.toList` are unique and `k` is the key for the value `v`, the lookup will find `(k, v)` in the list.
  have h_unique : ∀ (k' : α) (v' : β), (k', v') ∈ m.toList → k' = k → v' = m.get? k := by
    aesop;
  by_cases h : m.get? k = none <;> simp_all +decide [ List.lookup ];
  · exact fun a b hab => Ne.symm ( h_unique a b hab );
  · obtain ⟨ v, hv ⟩ := Option.ne_none_iff_exists'.mp ‹_›;
    have h_lookup : (k, v) ∈ m.toList := by
      grind;
    have h_unique : ∀ (l : List (α × β)), (l.map Prod.fst).Nodup → ∀ (k : α) (v : β), (k, v) ∈ l → List.lookup k l = some v := by
      intros l hl k v hv; induction l <;> simp_all +decide [ List.lookup ] ;
      cases hv <;> simp_all +decide [ Prod.ext_iff ];
      cases h : k == ‹α × β›.1 <;> simp_all +decide [ EquivBEq ];
    convert h_unique _ _ _ _ h_lookup;
    · grind;
    · exact?

/-
The label of a node in the new graph is its old label if it still has incident edges, otherwise it is removed.
-/
theorem DagLeanLibrary.SpecialDAG.Graph.deleteEdge_nodeLabel?_eq {g : Graph} {src dst : NodeId} {g' : Graph}
    (h : deleteEdge g src dst = some g') (n : NodeId) :
    g'.nodeLabel? n = if (g'.edges.any (fun (u, v) => u == n || v == n)) then g.nodeLabel? n else none := by
  -- By definition of `deleteEdge`, if `n` has no incident edges in `g'`, then `n` is removed from `g'.nodeLabels`.
  have h_delete : g'.nodeLabels = (g.nodeLabels.toList.filter (fun (k, v) => g'.edges.any (fun (u, v) => u == k || v == k))).foldl (fun acc (k, v) => acc.insert k v) (∅ : Std.HashMap NodeId String) := by
    unfold Graph.deleteEdge at h;
    simp +zetaDelta at *;
    rw [ ← h.2, List.foldl_filter ];
  -- By definition of `HashMap.ofList`, we can rewrite the right-hand side of the equation.
  have h_ofList : g'.nodeLabels = Std.HashMap.ofList (List.filter (fun (k, v) => g'.edges.any (fun (u, v) => u == k || v == k)) g.nodeLabels.toList) := by
    -- By definition of `Std.HashMap.ofList`, we can rewrite the right-hand side of the equation.
    have h_ofList : ∀ (l : List (NodeId × String)), Std.HashMap.ofList l = List.foldl (fun acc (k, v) => acc.insert k v) (∅ : Std.HashMap NodeId String) l := by
      intros l; exact (by
      induction l using List.reverseRecOn <;> simp +decide [ * ];
      simp_all +decide [ Std.HashMap.ofList ];
      simp_all +decide [ Std.DHashMap.Const.ofList ];
      congr;
      grind);
    rw [ h_ofList, h_delete ];
  have h_get? : g'.nodeLabels.get? n = (List.filter (fun (k, v) => g'.edges.any (fun (u, v) => u == k || v == k)) g.nodeLabels.toList).lookup n := by
    rw [h_ofList];
    apply DagLeanLibrary.SpecialDAG.Graph.ofList_get?_eq_lookup_of_nodup;
    have := DagLeanLibrary.SpecialDAG.Graph.HashMap_nodup_keys g.nodeLabels;
    grind;
  have h_lookup_filter : (List.filter (fun (k, v) => g'.edges.any (fun (u, v) => u == k || v == k)) g.nodeLabels.toList).lookup n = if g'.edges.any (fun (u, v) => u == n || v == n) then g.nodeLabels.toList.lookup n else none := by
    convert lookup_filter_eq_if _ _ _ using 1;
    convert rfl;
    rotate_right;
    exact fun n => g'.edges.any fun x => x.1 == n || x.2 == n;
    · rfl;
    · rfl;
    · infer_instance;
  convert h_get?.trans h_lookup_filter using 1;
  convert rfl;
  convert HashMap_get?_eq_lookup g.nodeLabels n |> Eq.symm

/-
If a node has a label in the new graph, it must have at least one incident edge.
-/
theorem DagLeanLibrary.SpecialDAG.Graph.deleteEdge_noIsolatedNodes {g : Graph} {src dst : NodeId} {g' : Graph}
    (h : deleteEdge g src dst = some g') :
    ∀ n, g'.nodeLabel? n ≠ none → g'.predecessors n ≠ [] ∨ g'.successors n ≠ [] := by
  intro n hn
  rw [deleteEdge_nodeLabel?_eq h] at hn
  split_ifs at hn with h_incident
  · exact incident_implies_pred_or_succ h_incident
  · contradiction

/-
The label-to-node map in the new graph is constructed by inverting the node-to-label map.
